# Server
PORT=4000
JWT_SECRET=change_me_to_a_very_long_random_string_at_least_32_chars

# Public URLs (used for OAuth redirect URIs)
# Local dev:
SERVER_URL=http://localhost:4000
CLIENT_ORIGIN=http://localhost:3000
# Production (Railway + Vercel):
# SERVER_URL=https://your-server.railway.app
# CLIENT_ORIGIN=https://your-app.vercel.app

# Database
# Local dev:  postgresql://trading:trading_secret@localhost:5432/trading_competition
# Railway:    paste the Railway Postgres connection URL here
DATABASE_URL=postgresql://trading:trading_secret@localhost:5432/trading_competition
# Enable SSL for production databases with a valid certificate chain.
# Local Docker/Postgres should stay false.
DATABASE_SSL=false

# Single-instance production lock. Keep one active backend process per database.
SINGLE_INSTANCE_LOCK_ID=42424201

# Order validation / abuse controls
MAX_ORDER_QTY=1000000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=120
ORDER_RATE_LIMIT_WINDOW_MS=60000
ORDER_RATE_LIMIT_MAX=300

# Google OAuth
# Get from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Price simulator tick interval in ms (1000 = 1 tick/second)
TICK_INTERVAL_MS=1000

# Market data provider:
# - simulated  : uses server/src/simulator/priceEngine.ts (good for tests/dev)
# - alpaca     : free real-time IEX feed via Alpaca paper-trading account (recommended)
# - polygon    : Polygon.io or Massive (requires paid WebSocket tier)
MARKET_DATA_PROVIDER=simulated

# How often to publish consolidated ticks into the app UI / order checker
MARKET_DATA_PUBLISH_MS=1000

# Alpaca market data (free — sign up at alpaca.markets, use paper-trading API keys)
# WebSocket: wss://stream.data.alpaca.markets/v2/iex  (no credit card required)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_SNAPSHOT_REFRESH_MS=60000

# Live Polygon / Massive market data (paid WebSocket tier required)
POLYGON_API_KEY=
MASSIVE_API_KEY=
POLYGON_FEED=delayed
POLYGON_SNAPSHOT_REFRESH_MS=60000
