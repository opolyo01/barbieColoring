# Server
PORT=4000
JWT_SECRET=change_me_to_a_long_random_string

# Database
# Local dev:  postgresql://trading:trading_secret@localhost:5432/trading_competition
# Railway:    paste the Railway Postgres connection URL here
DATABASE_URL=postgresql://trading:trading_secret@localhost:5432/trading_competition

# Kafka
# Local dev:  localhost:9092
# Upstash:    your-cluster.upstash.io:9092
KAFKA_BROKERS=localhost:9092

# Upstash Kafka (only needed when using Upstash)
KAFKA_USERNAME=
KAFKA_PASSWORD=

# Price simulator tick interval in ms (1000 = 1 tick/second)
TICK_INTERVAL_MS=1000
